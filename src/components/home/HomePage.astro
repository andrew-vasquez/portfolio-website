---
import { Image } from "astro:assets";
import BackgroundEffects from "@/components/home/BackgroundEffects.astro";
import { projectData } from "@/lib/projectData";
import { contactContent, heroContent, stackGroups } from "@/lib/siteContent";
import signatureWhite from "@/assets/signature/signature-white.png";

const [featuredProject, ...selectedProjects] = projectData;
const buttonBaseClasses =
  "radius-control inline-flex min-h-11 items-center justify-center gap-2 px-5 py-3 text-sm font-medium focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/50";
const macOsWindowControls = [
  "bg-white/28 shadow-[inset_0_1px_0_rgba(255,255,255,0.06),0_0_0_1px_rgba(255,255,255,0.03)]",
  "bg-white/22 shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_0_0_1px_rgba(255,255,255,0.025)]",
  "bg-white/16 shadow-[inset_0_1px_0_rgba(255,255,255,0.04),0_0_0_1px_rgba(255,255,255,0.02)]",
];

const getActionLinkClasses = (secondary = false) =>
  secondary
    ? `${buttonBaseClasses} button-secondary border border-white/10 bg-white/[0.03] text-white/88 hover:border-white/20 hover:bg-white/[0.06]`
    : `${buttonBaseClasses} button-primary border border-white/12 bg-white text-black hover:bg-[#dde6ee]`;
---

<svg xmlns="http://www.w3.org/2000/svg" class="hidden">
  <symbol id="icon-arrow-right" viewBox="0 0 24 24">
    <path d="M5 12h14m-6-6 6 6-6 6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
  </symbol>
  <symbol id="icon-arrow-up-right" viewBox="0 0 24 24">
    <path d="M7 17 17 7m-8 0h8v8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
  </symbol>
  <symbol id="icon-mail" viewBox="0 0 24 24">
    <path d="M4 6h16v12H4z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="2"></path>
    <path d="m4 7 8 6 8-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
  </symbol>
</svg>

<div class="portfolio-shell">
  <div class="portfolio-backdrop" aria-hidden="true"></div>
  <div class="portfolio-grid" aria-hidden="true"></div>
  <BackgroundEffects />

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <div class="relative z-10">
    <header class="safe-top mx-auto w-full max-w-[1200px] px-4 pt-6 sm:px-6 lg:px-8 lg:pt-8">
      <div class="surface-card radius-panel flex flex-wrap items-start justify-between gap-4 px-4 py-3 md:items-center sm:px-5">
        <div class="flex min-w-0 items-center gap-3">
          <div class="radius-control flex h-11 w-11 items-center justify-center border border-white/10 bg-white/[0.04]">
            <Image
              src={signatureWhite}
              alt="Andrew Vasquez initials"
              width="54"
              height="22"
              sizes="54px"
              loading="eager"
              fetchpriority="high"
              class="h-auto w-[3.4rem] brightness-125 contrast-125"
            />
          </div>
          <div>
            <p class="eyebrow mb-1">Andrew Vasquez</p>
            <p class="text-sm text-soft sm:text-[0.95rem]">Full-Stack Developer</p>
          </div>
        </div>
        <div class="flex w-full shrink-0 items-center justify-end gap-2 md:w-auto">
          <a
            href="https://github.com/andrew-vasquez"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View Andrew Vasquez on GitHub"
            class="icon-link radius-control inline-flex h-11 w-11 items-center justify-center border border-white/10 bg-white/[0.03] text-white/82 hover:border-white/20 hover:bg-white/[0.06] hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/50"
          >
            <img src="/icons/github.svg" alt="" width="16" height="16" decoding="async" class="h-4 w-4" />
          </a>
          <a
            href="https://www.linkedin.com/in/andrew-vasquez-000434237/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View Andrew Vasquez on LinkedIn"
            class="icon-link radius-control inline-flex h-11 w-11 items-center justify-center border border-white/10 bg-white/[0.03] text-white/82 hover:border-white/20 hover:bg-white/[0.06] hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/50"
          >
            <img src="/icons/linkedin.svg" alt="" width="16" height="16" decoding="async" class="h-4 w-4" />
          </a>
          <a
            href="mailto:avasdev98@gmail.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Email Me"
            class="icon-link radius-control inline-flex h-11 w-11 items-center justify-center border border-white/10 bg-white/[0.03] text-white/82 hover:border-white/20 hover:bg-white/[0.06] hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/50"
          >
            <svg class="h-4 w-4" aria-hidden="true"><use href="#icon-mail"></use></svg>
          </a>
        </div>
      </div>
    </header>

    <main
      id="main-content"
      class="safe-bottom mx-auto flex w-full max-w-[1200px] flex-col gap-16 px-4 pb-20 pt-8 sm:px-6 sm:pb-24 lg:gap-20 lg:px-8 lg:pt-12"
    >
      <section class="relative">
        <div
          class="motion-item radius-chip mb-6 inline-flex border border-white/10 bg-white/[0.03] px-4 py-2"
          data-reveal
          style="--reveal-delay: 0ms;"
        >
          <p class="eyebrow text-[0.68rem] text-white/72">{heroContent.pill}</p>
        </div>

        <div
          class="hero-title motion-item max-w-3xl text-[clamp(2.6rem,6.2vw,4.9rem)] font-semibold text-white"
          data-reveal
          data-reveal-hero
          style="--reveal-delay: 60ms;"
        >
          {heroContent.lines.map((line, lineIndex) => {
            const words = line.split(" ");

            return (
              <span class="block pb-1">
                {words.map((word, wordIndex) => (
                  <>
                    <span class="hero-word" style={`--word-index: ${lineIndex * 8 + wordIndex};`}>{word}</span>
                    {wordIndex < words.length - 1 && " "}
                  </>
                ))}
              </span>
            );
          })}
        </div>

        <div class="motion-item mt-5 max-w-2xl" data-reveal style="--reveal-delay: 120ms;">
          <p class="text-base leading-8 text-soft sm:text-lg">{heroContent.description}</p>
        </div>

        <div
          class="motion-item mt-8 flex flex-col gap-3 md:flex-row md:flex-wrap md:items-center"
          data-reveal
          style="--reveal-delay: 180ms;"
        >
          <a
            href={heroContent.primaryCta.href}
            class={`${getActionLinkClasses()} w-full justify-center md:w-auto`}
          >
            <span>{heroContent.primaryCta.label}</span>
            <svg class="h-4 w-4" aria-hidden="true"><use href="#icon-arrow-right"></use></svg>
          </a>
          <a
            href={heroContent.secondaryCta.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`${getActionLinkClasses(true)} w-full justify-center md:w-auto`}
          >
            <span>{heroContent.secondaryCta.label}</span>
            <svg class="h-4 w-4" aria-hidden="true"><use href="#icon-mail"></use></svg>
          </a>
        </div>

        <div class="mt-10 grid gap-3 md:grid-cols-3">
          {heroContent.meta.map((item, index) => (
            <div
              class="motion-item surface-card radius-card px-4 py-4 text-sm leading-6 text-soft"
              data-reveal
              style={`--reveal-delay: ${240 + index * 50}ms;`}
            >
              {item}
            </div>
          ))}
        </div>

        <section id="featured-work" class="mt-10 lg:mt-12">
          <div class="grid gap-5 lg:grid-cols-[1.18fr_0.92fr] lg:items-stretch">
            <div
              class="motion-item surface-panel radius-panel flex h-full flex-col overflow-hidden p-3"
              data-reveal
              style="--reveal-delay: 0ms;"
            >
              <div class="radius-card border border-white/10 bg-[#0d1015] p-3 shadow-[0_30px_120px_-50px_rgba(0,0,0,0.95)]">
                <div class="mb-3 flex items-center gap-2 px-1" aria-hidden="true">
                  {macOsWindowControls.map((controlClass) => (
                    <span class={`h-2.5 w-2.5 rounded-full ${controlClass}`}></span>
                  ))}
                </div>
                <div class="overflow-hidden rounded-[0.75rem] border border-white/10 bg-[#0a0d12]">
                  <Image
                  src={featuredProject.image}
                  alt={`Preview of ${featuredProject.title}`}
                  width={featuredProject.image.width}
                  height={featuredProject.image.height}
                  sizes="(max-width: 767px) calc(100vw - 3.5rem), (max-width: 1279px) 58vw, 690px"
                  loading="eager"
                  fetchpriority="high"
                  class="h-auto w-full object-contain"
                  />
                </div>
              </div>

              <div class="mt-4 flex flex-1 flex-col">
                <div class="mb-3 px-1">
                  <p class="eyebrow">Highlights</p>
                </div>
                <div class="grid flex-1 auto-rows-fr gap-3 md:grid-cols-2">
                {featuredProject.proofPoints.map((item, index) => (
                  <div
                    class={`motion-item radius-card flex h-full items-center border border-white/10 bg-white/[0.02] px-5 py-5 text-sm leading-7 text-soft ${
                      index === featuredProject.proofPoints.length - 1 ? "md:col-span-2" : ""
                    }`}
                    data-reveal
                    style={`--reveal-delay: ${120 + index * 55}ms;`}
                  >
                    {item}
                  </div>
                ))}
                </div>
              </div>
            </div>

            <div
              class="motion-item surface-panel radius-panel h-full p-6 sm:p-7"
              data-reveal
              style="--reveal-delay: 80ms;"
            >
              <p class="eyebrow mb-4">{featuredProject.category}</p>
              <h2 class="display-heading text-3xl font-semibold tracking-[-0.05em] text-white sm:text-4xl">
                {featuredProject.title}
              </h2>
              <p class="mt-3 max-w-xl text-base leading-7 text-soft sm:text-lg">{featuredProject.summary}</p>

              <div class="mt-6 grid gap-3 md:grid-cols-2">
                <div class="radius-card border border-white/10 bg-white/[0.025] p-4 md:col-span-2">
                  <p class="eyebrow mb-3">Role</p>
                  <p class="text-sm leading-7 text-soft sm:text-[0.98rem]">{featuredProject.role}</p>
                </div>
              </div>

              <div class="mt-6">
                <p class="eyebrow mb-3">Stack</p>
                <div class="flex flex-wrap gap-2">
                  {featuredProject.stack.map((item) => (
                    <span class="radius-chip border border-white/10 bg-white/[0.03] px-3 py-2 text-sm text-soft">
                      {item}
                    </span>
                  ))}
                </div>
              </div>

              <div class="mt-6">
                <a
                  href={featuredProject.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={getActionLinkClasses()}
                >
                  <span>Open Project</span>
                  <svg class="h-4 w-4" aria-hidden="true"><use href="#icon-arrow-up-right"></use></svg>
                </a>
              </div>
            </div>
          </div>

          <div class="motion-item mt-10 max-w-3xl lg:mt-12" data-reveal style="--reveal-delay: 0ms;">
            <p class="eyebrow mb-4">Skills</p>
            <h2 class="display-heading max-w-4xl text-balance text-4xl font-semibold tracking-[-0.05em] text-white sm:text-5xl">
              Frontend, backend, and tools.
            </h2>
          </div>

          <div class="mt-5 grid gap-4 md:grid-cols-3">
            {stackGroups.map((group, index) => (
              <article
                class="motion-item surface-card radius-card h-full p-5"
                data-reveal
                style={`--reveal-delay: ${70 + index * 60}ms;`}
              >
                <p class="eyebrow mb-4">{group.title}</p>
                <div class="grid grid-cols-2 gap-2">
                  {group.items.map((item) => (
                    <div class="radius-chip inline-flex items-center gap-2 border border-white/10 bg-white/[0.03] px-3 py-2">
                      <img src={item.image} alt={item.name} width="18" height="18" loading="lazy" decoding="async" class="h-[18px] w-[18px]" />
                      <span class="text-sm text-soft">{item.name}</span>
                    </div>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>
      </section>

      <section class="below-fold-section">
        <div class="motion-item max-w-3xl" data-reveal style="--reveal-delay: 0ms;">
          <p class="eyebrow mb-4">Projects</p>
          <h2 class="display-heading max-w-4xl text-balance text-4xl font-semibold tracking-[-0.05em] text-white sm:text-5xl">
            More projects
          </h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-soft sm:text-lg">A few other things I have built.</p>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-2">
          {selectedProjects.map((project, index) => (
            <article
              class="motion-item surface-card radius-panel group overflow-hidden"
              data-reveal
              style={`--reveal-delay: ${70 + index * 80}ms;`}
            >
              <div class="border-b border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.02),rgba(10,13,18,0.92))] p-3">
                <div class="radius-card border border-white/10 bg-[#0d1015] p-3 shadow-[0_30px_120px_-50px_rgba(0,0,0,0.95)]">
                  <div class="mb-3 flex items-center gap-2 px-1" aria-hidden="true">
                    {macOsWindowControls.map((controlClass) => (
                      <span class={`h-2.5 w-2.5 rounded-full ${controlClass}`}></span>
                    ))}
                  </div>
                  <div class="overflow-hidden rounded-[0.75rem] border border-white/10 bg-[#0a0d12]">
                    <Image
                      src={project.image}
                      alt={`Preview of ${project.title}`}
                      width={project.image.width}
                      height={project.image.height}
                      sizes="(max-width: 1023px) calc(100vw - 2rem), 560px"
                      loading="lazy"
                      decoding="async"
                      class="h-auto w-full object-contain transition-transform duration-300 ease-out group-hover:scale-[1.02]"
                    />
                  </div>
                </div>
              </div>
              <div class="p-6 sm:p-7">
                <div class="mb-4 flex items-start justify-between gap-4">
                  <div>
                    <p class="eyebrow mb-2">{project.category}</p>
                    <h3 class="display-heading text-[1.8rem] font-semibold tracking-[-0.04em] text-white">
                      {project.title}
                    </h3>
                  </div>
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="icon-link radius-control inline-flex h-11 w-11 items-center justify-center border border-white/10 bg-white/[0.03] text-white/82 group-hover:border-white/20 group-hover:bg-white/[0.06] group-hover:text-white"
                    aria-label={`Open ${project.title}`}
                  >
                    <svg class="h-4 w-4 transition-transform duration-200 ease-out group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true"><use href="#icon-arrow-up-right"></use></svg>
                  </a>
                </div>

                <p class="text-base leading-7 text-soft">{project.summary}</p>

                <div class="mt-5">
                  <p class="eyebrow mb-3">Role</p>
                  <p class="text-sm leading-6 text-soft">{project.role}</p>
                </div>

                <div class="mt-5 flex flex-wrap gap-2">
                  {project.stack.map((item) => (
                    <span class="radius-chip border border-white/10 bg-white/[0.03] px-3 py-2 text-sm text-soft">
                      {item}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="below-fold-section">
        <div
          class="motion-item surface-panel radius-panel px-6 py-8 sm:px-8 sm:py-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
          data-reveal
        >
          <div class="max-w-2xl">
            <p class="eyebrow mb-4">{contactContent.label}</p>
            <h2 class="display-heading text-4xl font-semibold tracking-[-0.05em] text-white sm:text-5xl">
              {contactContent.title}
            </h2>
            <p class="mt-4 text-base leading-7 text-soft sm:text-lg">{contactContent.description}</p>
          </div>

          <div class="mt-8 flex flex-col gap-3 md:flex-row md:flex-wrap lg:mt-0 lg:justify-end">
            <a href="mailto:avasdev98@gmail.com" target="_blank" rel="noopener noreferrer" class={`${getActionLinkClasses()} w-full justify-center md:w-auto`}>
              <span>Start A Conversation</span>
              <svg class="h-4 w-4" aria-hidden="true"><use href="#icon-mail"></use></svg>
            </a>
            <a
              href="https://github.com/andrew-vasquez"
              target="_blank"
              rel="noopener noreferrer"
              class={`${getActionLinkClasses(true)} w-full justify-center md:w-auto`}
            >
              <span>View GitHub</span>
              <svg class="h-4 w-4" aria-hidden="true"><use href="#icon-arrow-up-right"></use></svg>
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="safe-bottom mx-auto w-full max-w-[1200px] px-4 pb-8 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-3 border-t border-white/10 py-6 text-sm text-white/55 md:flex-row md:items-center md:justify-between">
        <p>&copy; 2026 Andrew Vasquez</p>
        
      </div>
    </footer>
  </div>
</div>

<script>
  import { initRevealMotion } from "@/scripts/revealMotion.js";

  initRevealMotion();
</script>
