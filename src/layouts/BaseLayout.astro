---
import "@/styles/global.css";
import {
  buildCanonical,
  buildSocialImage,
  siteDescription,
  siteName,
  siteTitle,
  siteUrl,
} from "@/lib/seo";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title = siteTitle,
  description = siteDescription,
  pathname = Astro.url.pathname,
} = Astro.props;

const canonicalUrl = buildCanonical(pathname);
const socialImage = buildSocialImage();
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: "Andrew Vasquez",
      url: siteUrl,
      jobTitle: "Software Engineer",
      sameAs: [
        "https://github.com/andrew-vasquez",
        "https://www.linkedin.com/in/andrew-vasquez-000434237/",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: siteName,
      description,
      publisher: {
        "@id": `${siteUrl}/#person`,
      },
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      isPartOf: {
        "@id": `${siteUrl}/#website`,
      },
      about: {
        "@id": `${siteUrl}/#person`,
      },
    },
  ],
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="theme-color" content="#07080a" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta
      name="keywords"
      content="Andrew Vasquez, Software Engineer, Full-Stack Developer, Frontend Developer, React Developer, TypeScript, Astro, Portfolio, UI Engineer"
    />
    <meta name="author" content="Andrew Vasquez" />
    <meta name="creator" content="Andrew Vasquez" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Preview of Andrew Vasquez portfolio work" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="robots" content="index,follow" />
    <meta name="googlebot" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Sans+Condensed:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
